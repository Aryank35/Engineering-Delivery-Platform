// Engineering Operations Platform — Prisma schema
// Phase 1: Authentication, RBAC and the audit trail foundation.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  ADMIN
  ENGINEERING_MANAGER
  BUSINESS_ANALYST
  DEVELOPER
  QA_ENGINEER
  VIEWER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl           String?
  timezone            String?
  capacityHoursPerDay Float     @default(6)
  isActive            Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]         @relation("AuditActor")
  reportedItems WorkItem[]         @relation("Reporter")
  assignedItems WorkItem[]         @relation("Assignee")
  comments      Comment[]
  activities    WorkItemActivity[] @relation("ActivityActor")
  timeLogs      TimeLog[]
  activeTimer   ActiveTimer?

  @@index([isActive])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  key         RoleKey  @unique
  name        String
  description String
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  resource    String
  action      String
  description String
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// A rotating refresh token. `family` groups a chain of rotated tokens so that
// reuse of a revoked token can revoke the entire chain (theft detection).
model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  family            String
  tokenHash         String
  userAgent         String?
  ip                String?
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Immutable record of every meaningful mutation across the platform.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// --- Phase 2: work-item hierarchy ------------------------------------------

enum WorkItemType {
  REQUIREMENT
  EPIC
  STORY
  TASK
}

enum WorkItemStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  IN_QA
  DONE
  CANCELLED
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  FIELD_CHANGED
}

// A single canonical work item. The type + self-referential parent express the
// Requirement → Epic → Story → Task hierarchy.
model WorkItem {
  id          String         @id @default(cuid())
  number      Int            @unique @default(autoincrement())
  type        WorkItemType
  title       String
  description String?
  status      WorkItemStatus @default(BACKLOG)
  priority    Priority       @default(NONE)
  storyPoints Int?
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?

  parentId String?
  parent   WorkItem?  @relation("Hierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children WorkItem[] @relation("Hierarchy")

  reporterId String
  reporter   User   @relation("Reporter", fields: [reporterId], references: [id], onDelete: Restrict)

  assigneeId String?
  assignee   User?   @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  // Ordering within a board column (same sprint + status). Lower = higher.
  rank     Float   @default(0)

  labels     WorkItemLabel[]
  comments   Comment[]
  activities WorkItemActivity[]
  timeLogs   TimeLog[]
  timers     ActiveTimer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([parentId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([sprintId, status])
  @@map("work_items")
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

// A time-boxed iteration. Work items are assigned to a sprint for board + capacity.
model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  startDate DateTime
  endDate   DateTime
  // Optional per-status WIP limits, e.g. { "IN_PROGRESS": 3 }.
  wipLimits Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  workItems WorkItem[]

  @@index([status])
  @@map("sprints")
}

// --- Phase 4: time tracking ------------------------------------------------

enum TimeLogSource {
  TIMER
  MANUAL
}

enum TimerStatus {
  RUNNING
  PAUSED
}

// A finalized chunk of time spent on a work item by a user.
model TimeLog {
  id          String        @id @default(cuid())
  workItemId  String
  userId      String
  seconds     Int
  description String?
  source      TimeLogSource @default(MANUAL)
  spentOn     DateTime      @db.Date
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, spentOn])
  @@index([workItemId])
  @@map("time_logs")
}

// A user's single in-progress stopwatch (start/pause/resume/stop → TimeLog).
model ActiveTimer {
  id                 String      @id @default(cuid())
  userId             String      @unique
  workItemId         String
  status             TimerStatus @default(RUNNING)
  accumulatedSeconds Int         @default(0)
  startedAt          DateTime    @default(now())
  lastStartedAt      DateTime?
  description        String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@map("active_timers")
}

model Label {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workItems WorkItemLabel[]

  @@map("labels")
}

model WorkItemLabel {
  workItemId String
  labelId    String

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  label    Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([workItemId, labelId])
  @@index([labelId])
  @@map("work_item_labels")
}

model Comment {
  id         String    @id @default(cuid())
  workItemId String
  authorId   String
  body       String
  editedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([workItemId])
  @@index([authorId])
  @@map("comments")
}

// Purpose-built timeline feed for a work item (created + per-field changes).
model WorkItemActivity {
  id         String       @id @default(cuid())
  workItemId String
  actorId    String?
  type       ActivityType
  field      String?
  data       Json?
  createdAt  DateTime     @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  actor    User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workItemId])
  @@index([createdAt])
  @@map("work_item_activities")
}
