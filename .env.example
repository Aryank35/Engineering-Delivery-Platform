# ---------------------------------------------------------------------------
# Copy to .env and adjust. Used by docker-compose and by apps/api (via dotenv).
# ---------------------------------------------------------------------------

# --- Postgres (docker-compose) ---
POSTGRES_USER=eop
POSTGRES_PASSWORD=eop
POSTGRES_DB=eop
POSTGRES_PORT=5432

# --- Redis (docker-compose) ---
REDIS_PORT=6379

# --- API ---
NODE_ENV=development
API_PORT=4000
API_GLOBAL_PREFIX=api
WEB_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://eop:eop@localhost:5432/eop?schema=public
REDIS_URL=redis://localhost:6379

# JWT — generate strong secrets, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL=7d
COOKIE_SECRET=dev-cookie-secret-change-me

# Rate limiting (requests per TTL seconds)
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Real-time: enable the Socket.IO Redis adapter for multi-node scaling (needs REDIS_URL).
# Leave false for single-node local dev.
REALTIME_REDIS_ENABLED=false

# --- Seed bootstrap admin (pnpm db:seed) ---
BOOTSTRAP_ADMIN_EMAIL=admin@eop.dev
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
BOOTSTRAP_ADMIN_NAME=Platform Admin

# --- Web (Vite) ---
VITE_API_URL=http://localhost:4000/api
